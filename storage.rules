rules_version = '2';

// Craft rules based on data model in firebase-blueprint.json
service firebase.storage {
  match /b/{bucket}/o {
    // Helper function to check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    // Helper function to check if user is an admin
    function isAdmin() {
      return isAuthenticated() && 
        (request.auth.token.email == "noviharyanto062@gmail.com");
    }

    // Employees documents
    match /employees/{allPaths=**} {
      // Allow authenticated users to read
      allow read: if isAuthenticated();
      
      // Allow authenticated users to write (for testing)
      allow write: if isAuthenticated();
      allow delete: if isAdmin();
    }
    
    // Settings (logos, etc)
    match /settings/{allPaths=**} {
      allow read: if true;
      allow write, delete: if isAdmin();
    }
  }
}
